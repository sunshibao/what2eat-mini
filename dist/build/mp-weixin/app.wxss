page{--w2e-orange: #ff6b35;--w2e-orange-deep: #e85a25;--w2e-orange-soft: #fff3ee;--w2e-ink: #1a1a1a;--w2e-text: #333333;--w2e-text-2: #6b6b6b;--w2e-text-3: #9a9a9a;--w2e-line: #ececec;--w2e-bg: #ffffff;--w2e-bg-soft: #f8f9fa;--w2e-shadow-orange: 0 24rpx 48rpx -16rpx rgba(255, 107, 53, .45);--w2e-shadow-card: 0 12rpx 32rpx -8rpx rgba(20, 20, 20, .06);background:var(--w2e-bg);color:var(--w2e-text);font-family:PingFang SC,HarmonyOS Sans,Source Han Sans CN,Hiragino Sans GB,system-ui,sans-serif;font-feature-settings:"palt";-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}view,text,button,input,textarea{box-sizing:border-box}button:after{border:none}.w2e-display{font-family:Times New Roman,Songti SC,"Source Han Serif CN",serif;font-style:italic;letter-spacing:-.02em}.w2e-eyebrow{font-size:22rpx;letter-spacing:.4em;text-transform:uppercase;color:var(--w2e-text-3)}.w2e-divider{width:48rpx;height:2rpx;background:var(--w2e-ink);display:inline-block}.w2e-safe-bottom{padding-bottom:env(safe-area-inset-bottom)}@keyframes w2e-fade-up{0%{opacity:0;transform:translateY(24rpx)}to{opacity:1;transform:translateY(0)}}@keyframes w2e-pulse{0%,to{transform:scale(1);box-shadow:var(--w2e-shadow-orange)}50%{transform:scale(1.02);box-shadow:0 28rpx 56rpx -16rpx rgba(255,107,53,.6)}}
